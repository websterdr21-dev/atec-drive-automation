SERVICE_ACCOUNT_PATH=C:/path/to/service_account.json
ANTHROPIC_API_KEY=sk-ant-...
SHARED_DRIVE_ID=your_shared_drive_id_here
GMAIL_ADDRESS=dylan@atec.co.za
APP_PASSWORD=your_web_ui_password_here

# Telegram bot (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=          # from @BotFather
TELEGRAM_ALLOWED_USERS=      # comma-separated Telegram user IDs, e.g. 123456789,987654321
TELEGRAM_WEBHOOK_SECRET=     # any random string for webhook verification

# Set to "true" for local dev (polling mode — no public URL needed)
# Leave unset on Railway (webhook mode used automatically)
TELEGRAM_USE_POLLING=true
